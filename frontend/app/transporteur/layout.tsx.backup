"use client";
import { useEffect, useState } from "react";
import { useRouter } from "next/navigation";
import { LanguageProvider } from "@/contexts/LanguageContext";
import { ThemeProvider } from "@/contexts/ThemeContext";
import SidebarTransporteur from "@/components/transporteur/SidebarTransporteur";

export default function TransporteurLayout({
  children,
}: {
  children: React.ReactNode;
}) {
  const router = useRouter();
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const checkAuth = () => {
      const token = localStorage.getItem("token");
      const userData = localStorage.getItem("user");
      
      console.log("🔍 Layout Transporteur - Vérification");
      
      if (!token) {
        console.log("❌ Pas de token, redirection login");
        router.replace("/auth/login");
        return;
      }

      if (userData) {
        try {
          const user = JSON.parse(userData);
          console.log("👤 Utilisateur:", { name: user.name, role: user.role });
          
          if (user.role !== "transporteur") {
            console.log("❌ Rôle incorrect, redirection dashboard");
            router.replace("/dashboard");
            return;
          }
          
          console.log("✅ Authentification réussie");
          setIsAuthenticated(true);
        } catch (e) {
          console.error("Erreur parsing user:", e);
          router.replace("/auth/login");
          return;
        }
      } else {
        console.log("❌ Pas de userData, redirection login");
        router.replace("/auth/login");
        return;
      }
      
      setIsLoading(false);
    };
    
    checkAuth();
  }, [router]);

  if (isLoading || !isAuthenticated) {
    return (
      <div style={{ 
        minHeight: "100vh", 
        display: "flex", 
        alignItems: "center", 
        justifyContent: "center",
        background: "#0a0a0a"
      }}>
        <div style={{ textAlign: "center" }}>
          <div style={{ 
            width: "48px", 
            height: "48px", 
            border: "3px solid #1a1a1a", 
            borderTopColor: "#667eea", 
            borderRadius: "50%", 
            animation: "spin 1s linear infinite",
            margin: "0 auto 16px"
          }}></div>
          <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
          <p style={{ color: "#94a3b8", marginTop: "16px" }}>Chargement de l'espace transporteur...</p>
        </div>
      </div>
    );
  }

  return (
    <LanguageProvider>
      <ThemeProvider>
        <div style={{ display: "flex", minHeight: "100vh" }}>
          <SidebarTransporteur />
          <div style={{ 
            flex: 1, 
            marginLeft: "280px",  // Largeur fixe de la sidebar
            minHeight: "100vh",
            background: "#0a0a0a"
          }}>
            {children}
          </div>
        </div>
      </ThemeProvider>
    </LanguageProvider>
  );
}